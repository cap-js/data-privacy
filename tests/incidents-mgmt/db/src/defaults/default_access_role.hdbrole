{
  "role": {
    "name": "default_access_role",
    "pattern_escape_character": "/",
    "schema_privileges": [
      {
        "privileges": [
          "INSERT",
          "UPDATE",
          "DELETE",
          "EXECUTE",
          "CREATE TEMPORARY TABLE",
          "SELECT CDS METADATA"
        ]
      }
    ],
    "schema_roles": [
      {
        "names": [
          "sap.ilm.RestrictBlockedDataAccess"
        ]
      }
    ]
  }
}
